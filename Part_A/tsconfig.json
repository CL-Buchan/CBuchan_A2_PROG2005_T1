{
	"compilerOptions": {
		"rootDir": "./app/scripts",
		"outDir": "./dist",

		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"types": ["node"],

		"sourceMap": false,
		"declaration": false,
		"declarationMap": false,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		"strict": true,
		"jsx": "react-jsx",
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"exclude": ["dist", "app/scripts/types", "node_modules"]
}
